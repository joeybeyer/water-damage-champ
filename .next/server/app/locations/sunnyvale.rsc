c:T638,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Does Sunnyvale have flood zones?","acceptedAnswer":{"@type":"Answer","text":"Yes, FEMA has designated certain areas of Sunnyvale as Special Flood Hazard Areas (SFHA), particularly near Permanente Creek and low-lying areas around the Baylands. Properties in these zones require flood insurance."}},{"@type":"Question","name":"How does storm water affect Sunnyvale homes?","acceptedAnswer":{"@type":"Answer","text":"Winter storms can overwhelm drainage systems in older neighborhoods like Heritage District and Lakewood, causing basement flooding and water intrusion in homes with inadequate waterproofing."}},{"@type":"Question","name":"Are there rivers near Sunnyvale that cause flooding?","acceptedAnswer":{"@type":"Answer","text":"Permanente Creek and San Francisco Bay adjacent areas are primary flood concerns. The creek can overflow during heavy rains, affecting homes near Fremont Avenue and Mathilda Avenue."}},{"@type":"Question","name":"What water damage risks exist in newer developments?","acceptedAnswer":{"@type":"Answer","text":"Newer neighborhoods like Cumberland and Sunnyvale West may face issues from improper grading or drainage around newer construction, especially during first winters."}},{"@type":"Question","name":"Does sea level rise affect Sunnyvale?","acceptedAnswer":{"@type":"Answer","text":"Climate change is increasing inland flooding risk due to sea level rise. Low-lying areas near the Bay are increasingly vulnerable to combined tidal and storm surge flooding."}}]}2:[["$","section",null,{"className":"py-16 md:py-24","children":["$","div",null,{"className":"max-w-7xl mx-auto px-4","children":[["$","nav",null,{"className":"text-sm text-gray-400 mb-6","children":[["$","$L8",null,{"href":"/","className":"hover:text-white","children":"Home"}],["$","span",null,{"className":"mx-2","children":"/"}],["$","$L8",null,{"href":"/locations","className":"hover:text-white",